@model BTCPayServer.Plugins.Boltz.Arkade.Models.ArkDashboardWidgetViewModel
@using BTCPayServer.Plugins.Boltz.Arkade.Models
@{
    var heading = Model.Issue switch
    {
        ArkDashboardPaymentIssue.Lightning => "Lightning payments are unavailable",
        ArkDashboardPaymentIssue.ArkadeAndLightning => "Arkade and Lightning payments are unavailable",
        _ => "Arkade payments are unavailable"
    };
}

<a asp-controller="Ark"
   asp-action="StoreOverview"
   asp-route-storeId="@Model.StoreId"
   class="widget border border-danger border-2 text-reset text-decoration-none d-block"
   style="--widget-padding: var(--btcpay-space-m); order: -4;"
   data-testid="ark-dashboard-widget">
    <div class="d-flex flex-column flex-sm-row align-items-sm-center gap-3">
        <div class="d-flex align-items-start gap-3 min-w-0">
            <span class="text-danger fs-4 lh-1 flex-shrink-0">
                <vc:icon symbol="warning" />
            </span>
            <div class="min-w-0">
                <h3 class="h4 text-danger mb-0" text-translate="true">@heading</h3>
            </div>
        </div>
        <span class="btn btn-sm btn-danger ms-sm-auto flex-shrink-0" text-translate="true">Review</span>
    </div>
</a>
