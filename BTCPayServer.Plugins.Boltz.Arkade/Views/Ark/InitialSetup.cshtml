@using BTCPayServer.Abstractions.Contracts
@using BTCPayServer.Abstractions.Extensions
@using BTCPayServer.Plugins.Boltz.Arkade.Models
@model BTCPayServer.Plugins.Boltz.Arkade.Models.InitialWalletSetupViewModel
@inject IScopeProvider ScopeProvider

@{
    Layout = "_LayoutWizard";
    ViewData.SetActivePage(category: "Ark", activePage: "initialSetup", title: "Arkade - Getting Started");
    var storeId = ScopeProvider.GetCurrentStoreId();
    var hasValidationError = !ViewData.ModelState.IsValid;
    var hasWalletValue = !string.IsNullOrEmpty(Model.Wallet);
    var settlementValidationError = ViewData.ModelState
        .Where(entry => entry.Key.StartsWith(nameof(Model.SettlementInputs), StringComparison.Ordinal))
        .Any(entry => entry.Value?.Errors.Count > 0);
    var importExistingActive = hasWalletValue;
    var createNewActive = !hasWalletValue && hasValidationError;
    var settlementStepActive = settlementValidationError && (importExistingActive || createNewActive);
}

@* Close X in the wizard navbar — mirrors BTCPay's own wallet-setup
   wizard chrome so the merchant can bail out back to the dashboard. *@
@section Navbar {
    <a asp-controller="UIStores" asp-action="Dashboard" asp-route-storeId="@storeId" class="cancel">
        <vc:icon symbol="cross" />
    </a>
}

<header class="text-center">
    <h1>Set up Arkade</h1>
    <p class="lead text-secondary mt-3" data-setup-subtitle>@(settlementStepActive ? "Configure settlement options for this wallet." : "Choose how this store should receive payments.")</p>
</header>

<div class="mt-5 @(settlementStepActive && createNewActive ? "d-none" : "")" data-setup-group>
    <div data-setup-choice class="@(settlementStepActive ? "d-none" : "")">
        <h3 class="my-4">I have a wallet</h3>
        <div class="list-group">
            <a href="#" class="list-group-item list-group-item-action" data-bs-toggle="collapse" data-bs-target="#importExisting" data-testid="import-wallet-option">
                <div class="image">
                    <vc:icon symbol="wallet-existing"/>
                </div>
                <div class="content">
                    <h4>Use an existing wallet</h4>
                    <p class="mb-0 text-secondary">Restore from a BIP-39 seed phrase</p>
                </div>
                <vc:icon symbol="caret-right" />
            </a>
        </div>
    </div>

    <div id="importExisting" class="collapse mt-3 @(importExistingActive ? "show" : "")">
        <div class="card">
            <div class="card-body">
                <form asp-action="InitialSetup" method="post" asp-route-storeId="@storeId" id="importExistingForm">
                    <div data-wallet-step class="@(settlementValidationError && importExistingActive ? "d-none" : "")">
                        <div class="form-group mb-3">
                            <label asp-for="Wallet" class="form-label">Seed phrase</label>
                            <input asp-for="Wallet" class="form-control" placeholder="seed phrase" id="existingWalletInput" required data-testid="wallet-import-input"/>
                            <span asp-validation-for="Wallet" class="text-danger"></span>
                            <div class="form-text mt-2">
                                Restore an HD wallet from its 12 or 24-word BIP-39 mnemonic.
                            </div>
                        </div>
                        <button type="button" class="btn btn-primary" data-settlement-next data-testid="import-wallet-next-btn">Continue</button>
                    </div>
                    <partial name="_InitialSettlementOptions" model="Model" view-data='new ViewDataDictionary(ViewData) {
                        { "SettlementPrefix", "importExisting" },
                        { "SubmitTestId", "import-wallet-btn" },
                        { "SubmitLabel", "Import Wallet" },
                        { "WalletStepLabel", "Existing wallet" },
                        { "ShowSettlementStep", settlementValidationError && importExistingActive }
                    }' />
                </form>
            </div>
        </div>
    </div>
</div>

<div class="mt-5 @(settlementStepActive && !createNewActive ? "d-none" : "")" data-setup-group>
    <div data-setup-choice class="@(settlementStepActive ? "d-none" : "")">
        <h3 class="my-4">I don't have a wallet</h3>
        <div class="list-group">
            <a href="#createNew" class="list-group-item list-group-item-action" data-settlement-direct="#createNew" data-testid="hd-wallet-option">
                <div class="image">
                    <vc:icon symbol="wallet-new"/>
                </div>
                <div class="content">
                    <h4>Create a new wallet</h4>
                    <p class="mb-0 text-secondary">Generate a brand-new hot wallet</p>
                </div>
                <vc:icon symbol="caret-right"/>
            </a>
        </div>
    </div>

    <div id="createNew" class="collapse mt-3 @(createNewActive ? "show" : "")">
        <div class="card">
            <div class="card-body">
                <form asp-action="InitialSetup" method="post" asp-route-storeId="@storeId" id="createNewForm">
                    <input type="hidden" asp-for="Wallet" value="" />
                    <partial name="_InitialSettlementOptions" model="Model" view-data='new ViewDataDictionary(ViewData) {
                        { "SettlementPrefix", "createNew" },
                        { "SubmitTestId", "create-wallet-btn" },
                        { "SubmitLabel", "Create Wallet" },
                        { "WalletStepLabel", "New hot wallet" },
                        { "ShowSettlementStep", true }
                    }' />
                </form>
            </div>
        </div>
    </div>
</div>

@section PageFootContent {
    <partial name="_SettlementRadioSyncScript" />
    <script>
        const showSettlementStep = form => {
            const currentGroup = form.closest('[data-setup-group]');
            document.querySelectorAll('[data-setup-group]').forEach(group => {
                group.classList.toggle('d-none', group !== currentGroup);
            });
            document.querySelectorAll('[data-setup-choice]').forEach(choice => {
                choice.classList.add('d-none');
            });
            const subtitle = document.querySelector('[data-setup-subtitle]');
            if (subtitle) {
                if (!subtitle.dataset.defaultText) {
                    subtitle.dataset.defaultText = subtitle.textContent;
                }
                subtitle.textContent = 'Configure settlement options for this wallet.';
            }

            form.querySelector('[data-wallet-step]')?.classList.add('d-none');
            const settlementStep = form.querySelector('[data-settlement-step]');
            settlementStep.classList.remove('d-none');
            settlementStep.querySelector('[data-settlement-focus], input, button')?.focus();
        };

        document.querySelectorAll('[data-settlement-next]').forEach(button => {
            button.addEventListener('click', () => {
                const form = button.closest('form');
                if (!form.reportValidity()) return;
                showSettlementStep(form);
            });
        });

        document.querySelectorAll('[data-settlement-direct]').forEach(link => {
            link.addEventListener('click', event => {
                event.preventDefault();
                const target = document.querySelector(link.dataset.settlementDirect);
                const form = target?.querySelector('form');
                if (!target || !form) return;

                target.classList.add('show');
                showSettlementStep(form);
            });
        });

        document.querySelectorAll('[data-settlement-back]').forEach(button => {
            button.addEventListener('click', () => {
                const form = button.closest('form');
                form.querySelector('[data-settlement-step]').classList.add('d-none');
                const walletStep = form.querySelector('[data-wallet-step]');
                walletStep?.classList.remove('d-none');

                document.querySelectorAll('[data-setup-group]').forEach(group => {
                    group.classList.remove('d-none');
                });
                document.querySelectorAll('[data-setup-choice]').forEach(choice => {
                    choice.classList.remove('d-none');
                });
                const collapse = form.closest('.collapse');
                if (!walletStep && collapse) {
                    if (window.bootstrap) {
                        bootstrap.Collapse.getOrCreateInstance(collapse, { toggle: false }).hide();
                    } else {
                        collapse.classList.remove('show');
                    }
                }
                const subtitle = document.querySelector('[data-setup-subtitle]');
                if (subtitle?.dataset.defaultText) {
                    subtitle.textContent = subtitle.dataset.defaultText;
                }
                const focusTarget = walletStep?.querySelector('input, button') ??
                    document.querySelector(`[data-settlement-direct="#${form.closest('.collapse')?.id}"]`);
                focusTarget?.focus();
            });
        });
    </script>
}
