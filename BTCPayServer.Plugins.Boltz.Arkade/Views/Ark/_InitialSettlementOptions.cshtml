@using BTCPayServer.Plugins.Boltz.Arkade.Models
@using BTCPayServer.Plugins.Boltz.Arkade.PaymentHandler
@model BTCPayServer.Plugins.Boltz.Arkade.Models.InitialWalletSetupViewModel

@{
    var prefix = ViewData["SettlementPrefix"] as string ?? "settlement";
    var submitTestId = ViewData["SubmitTestId"] as string ?? "settlement-submit-btn";
    var submitLabel = ViewData["SubmitLabel"] as string ?? "Continue";
    var walletStepLabel = ViewData["WalletStepLabel"] as string ?? "Wallet details";
    var showStep = ViewData["ShowSettlementStep"] as bool? == true;
}

<div data-settlement-step data-testid="settlement-step" class="@(showStep ? "" : "d-none")">
    <div class="border rounded p-3 mb-4 bg-light">
        <div class="text-secondary small">Wallet</div>
        <div class="fw-semibold">@walletStepLabel</div>
    </div>

    <div class="mb-3">
        <h3 class="h5 mb-1">Settlement</h3>
        <p class="text-secondary mb-0">Choose one destination for Arkade funds. You can change this later, and only one method settles at a time.</p>
    </div>

    @{
        // Off is the default: creating a wallet without touching this step must
        // succeed. A validation-error re-render keeps the submitted choice
        // pre-checked; a submitted selection with no method is the explicit
        // "Off" choice.
        var defaultSelectedType = Model.SettlementSelectionSubmitted
            ? Model.SelectedSettlement
            : null;
    }
    <div class="vstack gap-3 mb-4" data-settlement-form>
        <div class="border rounded p-3" data-testid="settlement-option-off">
            <label class="d-flex gap-2 align-items-start m-0" role="button">
                <input class="form-check-input mt-1" type="radio" name="activeSettlement"
                       value="@StoreSettlementOptionKeys.None" data-settlement-radio
                       checked="@(defaultSelectedType is null ? "checked" : null)" />
                <span>
                    <span class="fw-semibold d-block">Off</span>
                    <span class="text-secondary small">Keep funds in the Arkade wallet for now.</span>
                </span>
            </label>
        </div>

        @foreach (var option in Model.SettlementOptions)
        {
            var optionSlug = option.Type switch
            {
                StoreSettlementOption.BitcoinMainchain => "mainchain",
                _ => option.Type.ToString()
            };
            var optionTestId = $"settlement-option-{optionSlug}";
            var optionKey = StoreSettlementOptionKeys.GetKey(option.Type);
            var fieldsId = $"{prefix}-settlement-fields-{optionSlug}";
            var isDefault = option.Available && option.Type == defaultSelectedType;

            <div class="border rounded p-3 @(option.Available ? "" : "bg-light")"
                 data-testid="@optionTestId"
                 aria-disabled="@(!option.Available)">
                <label class="d-flex gap-2 align-items-start m-0" role="button">
                    <input class="form-check-input mt-1" type="radio" name="activeSettlement"
                           value="@optionKey" data-settlement-radio data-settlement-target="#@fieldsId"
                           checked="@(isDefault ? "checked" : null)"
                           disabled="@(option.Available ? null : "disabled")" />
                    <span class="min-w-0">
                        <span class="fw-semibold d-flex flex-wrap align-items-center gap-2">
                            @option.Title
                            @if (!option.Available)
                            {
                                <span class="badge bg-white text-muted border" data-testid="@($"{optionTestId}-disabled")">Unavailable</span>
                            }
                        </span>
                        <span class="text-secondary small d-block">@option.Description</span>
                    </span>
                </label>

                @if (option.Available && option.Data is { } optionData)
                {
                    <div id="@fieldsId" data-settlement-fields class="mt-3 @(isDefault ? "" : "d-none")">
                        @if (option.Type == StoreSettlementOption.BitcoinMainchain)
                        {
                            var thresholdValue = optionData.Value<string>(MainchainSettlementData.ThresholdKey);
                            var minSats = optionData.Value<long?>(MainchainSettlementData.MinSatsKey);
                            var maxSats = optionData.Value<long?>(MainchainSettlementData.MaxSatsKey);
                            var thresholdField = SettlementInputName.Field(option.Type, MainchainSettlementData.ThresholdKey);
                            var thresholdInputId = $"{prefix}{option.Type}{MainchainSettlementData.ThresholdKey}";
                            var thresholdHelp = minSats is not null && maxSats is not null
                                ? $"Allowed range: {minSats.Value:#,0}-{maxSats.Value:#,0} sats."
                                : "Boltz limits could not be loaded.";

                            <label for="@thresholdInputId" class="form-label">Settlement threshold</label>
                            <div class="input-group">
                                <input id="@thresholdInputId"
                                       name="@thresholdField"
                                       value="@thresholdValue"
                                       class="form-control"
                                       type="number"
                                       min="@(minSats ?? 0)"
                                       max="@maxSats"
                                       step="1"
                                       placeholder="Minimum"
                                       data-settlement-focus
                                       data-testid="settlement-threshold-input" />
                                <span class="input-group-text">sats</span>
                            </div>
                            @Html.ValidationMessage(thresholdField, null, new { @class = "text-danger" })
                            <div class="form-text mt-2">
                                @thresholdHelp
                            </div>
                        }
                    </div>
                }
                else if (!option.Available)
                {
                    <div class="alert alert-warning small mb-0 mt-3"
                         data-settlement-focus
                         data-testid="@($"settlement-{optionSlug}-requirement")"
                         tabindex="-1">
                        @option.UnavailableReason
                    </div>
                }
            </div>
        }
    </div>

    <div class="d-flex flex-wrap gap-2">
        <button type="button" class="btn btn-secondary" data-settlement-back>Back</button>
        <button name="command" type="submit" value="save" class="btn btn-primary" data-testid="@submitTestId">@submitLabel</button>
    </div>
</div>
