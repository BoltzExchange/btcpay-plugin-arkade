@using BTCPayServer.Abstractions.Contracts
@using BTCPayServer.Abstractions.Extensions
@using BTCPayServer.Data
@using BTCPayServer.Plugins.ArkPayServer.Models
@using BTCPayServer.Plugins.ArkPayServer.Services
@using BTCPayServer.Services
@using NArk.Abstractions.Wallets
@using NArk.Swaps.Models
@model BTCPayServer.Plugins.ArkPayServer.Models.StoreOverviewViewModel
@inject DisplayFormatter DisplayFormatter
@inject IScopeProvider ScopeProvider

@{
    ViewData.SetActivePage(category: "Ark", activePage: "StoreOverview", title: "Arkade");
    var storeId = ScopeProvider.GetCurrentStoreId();

    string FormatSats(long? sats) => sats.HasValue ? $"{sats.Value:N0} sats" : "Unavailable";

    string? Unit(StoreOverviewStatUnit unit) =>
        unit == StoreOverviewStatUnit.Sats ? "sats" : null;

    string FormatFeeRate(decimal? percentage) =>
        percentage.HasValue ? $"{percentage.Value * 100m:0.##}%" : "Unavailable";

    string? FormatNetworkFee(long? minerFee) =>
        minerFee is > 0 ? $"{minerFee.Value:N0} sats network" : null;

    string StatusLabel(RecentPaymentViewModel payment) =>
        payment.PaymentStatus switch
        {
            PaymentStatus.Settled => "Settled",
            PaymentStatus.Processing => "Processing",
            PaymentStatus.Unaccounted => "Needs review",
            _ => payment.SwapStatus switch
            {
                ArkSwapStatus.Pending or ArkSwapStatus.Unknown => "Pending",
                ArkSwapStatus.Settled => "Settled",
                ArkSwapStatus.Failed => "Failed",
                ArkSwapStatus.Refunded => "Refunded",
                _ => "Unknown"
            }
        };

    string StatusClass(RecentPaymentViewModel payment) =>
        payment.PaymentStatus switch
        {
            PaymentStatus.Settled => "text-bg-success",
            PaymentStatus.Processing => "text-bg-warning",
            PaymentStatus.Unaccounted => "text-bg-danger",
            _ => payment.SwapStatus switch
            {
                ArkSwapStatus.Pending or ArkSwapStatus.Unknown => "text-bg-warning",
                ArkSwapStatus.Settled => "text-bg-success",
                ArkSwapStatus.Failed => "text-bg-danger",
                ArkSwapStatus.Refunded => "text-bg-secondary",
                _ => "text-bg-secondary"
            }
        };

    bool IsFinalizingPayment(RecentPaymentViewModel payment) =>
        payment.SwapStatus is ArkSwapStatus.Pending or ArkSwapStatus.Unknown;

    var receiveNetworkFee = Model.IsLightningEnabled ? FormatNetworkFee(Model.BoltzReverseMinerFee) : null;
    var sendNetworkFee = Model.IsLightningEnabled ? FormatNetworkFee(Model.BoltzSubmarineMinerFee) : null;
}

<partial name="_StatusMessage" />

<div class="d-sm-flex align-items-start justify-content-between gap-3 mb-4">
    <div class="min-w-0">
        <h2 class="mb-1">Arkade</h2>
        @if (Model.Balances != null)
        {
            <partial name="_ArkBalances" model="Model.Balances" view-data='new ViewDataDictionary(ViewData) { { "CompactMode", true }, { "NoContainer", true } }' />
        }
    </div>
    <div class="d-flex flex-wrap gap-2 mt-3 mt-sm-0">
        <a asp-action="Receive" asp-route-storeId="@storeId" class="btn btn-primary" data-testid="receive-btn">
            <vc:icon symbol="actions-receive" />
            Receive
        </a>
        @if (Model.CanManagePrivateKeys)
        {
            <a asp-action="Send" asp-route-storeId="@storeId" class="btn btn-secondary" data-testid="send-btn">
                <vc:icon symbol="actions-send" />
                Send
            </a>
        }
        <div class="dropdown">
            <button class="btn btn-secondary dropdown-toggle" type="button" id="WalletActionsDropdownToggle" data-bs-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
                Actions
            </button>
            <div class="dropdown-menu dropdown-menu-end" aria-labelledby="WalletActionsDropdownToggle">
                <a asp-action="Settings" asp-route-storeId="@storeId" class="dropdown-item" data-testid="settings-btn">Settings</a>
                <form asp-action="SyncWallet" method="post" asp-route-storeId="@storeId">
                    <button type="submit" class="dropdown-item" data-testid="sync-wallet-btn">Sync wallet</button>
                </form>
                @if (Model.CanManagePrivateKeys)
                {
                    <form asp-action="Rescan" asp-route-storeId="@storeId" method="post">
                        <button type="submit"
                                class="dropdown-item"
                                title="Rescan the indexer and Boltz to rebuild contracts, derivation index, funds, and swaps for this wallet"
                                data-testid="rescan-wallet-btn">
                            Rescan wallet
                        </button>
                    </form>
                }
                @if (Model.SignerAvailable && !string.IsNullOrEmpty(Model.Wallet) && Model.CanManagePrivateKeys)
                {
                    <form method="post" asp-controller="Ark" asp-action="ShowPrivateKey" asp-route-storeId="@storeId">
                        <button type="submit" class="dropdown-item" data-testid="show-private-key-btn">
                            @(Model.WalletType == WalletType.HD ? "Show seed" : "Show key")
                        </button>
                    </form>
                }
                <a asp-action="DownloadWalletLog" asp-route-storeId="@storeId"
                   class="dropdown-item"
                   title="Download this wallet's diagnostic log to share with support"
                   data-testid="download-wallet-log-btn">
                    Download diagnostic log
                </a>
                <button type="button" class="dropdown-item text-danger" data-bs-toggle="modal" data-bs-target="#clearWalletModal" data-testid="clear-wallet-btn">
                    Clear wallet
                </button>
            </div>
        </div>
    </div>
</div>

@if (!string.IsNullOrEmpty(Model.DefaultAddress) && Model.WalletType == WalletType.SingleKey)
{
    <div class="mb-4">
        <label class="text-muted small">Receive address</label>
        <div class="input-group">
            <input type="text" class="form-control font-monospace" value="@Model.DefaultAddress" readonly data-testid="receive-address" />
            <button type="button" class="btn btn-outline-secondary" data-clipboard="@Model.DefaultAddress" data-testid="copy-address-btn" title="Copy to clipboard">
                <vc:icon symbol="actions-copy" />
            </button>
        </div>
    </div>
}

@if (Model.HasPaymentServiceIssue)
{
    <div class="alert alert-danger d-flex gap-3 align-items-start mb-4" role="alert">
        <div class="fs-3 lh-1">
            <vc:icon symbol="warning" />
        </div>
        <div>
            @if (!Model.ArkOperatorConnected)
            {
                <div>
                    <h3 class="h5 mb-1">Arkade payments are unavailable</h3>
                    <p class="mb-0">Ark Operator is currently offline. Try again later.</p>
                </div>
            }
            @if (Model.IsLightningEnabled && !string.IsNullOrEmpty(Model.BoltzUrl) && !Model.BoltzConnected)
            {
                <div class="@(!Model.ArkOperatorConnected ? "mt-3" : "")">
                    <h3 class="h5 mb-1">Lightning payments are unavailable</h3>
                    <p class="mb-0">Boltz is currently offline. Try again later.</p>
                </div>
            }
        </div>
    </div>
}

@if (Model.ShouldWarnWalletBackup)
{
    <div class="bg-tile rounded border-start border-warning border-4 d-flex flex-column flex-lg-row align-items-lg-center justify-content-between gap-3 p-3 p-sm-4 mb-3" role="alert" data-testid="wallet-backup-warning">
        <div class="d-flex gap-3 align-items-start">
            <div class="badge text-bg-warning rounded-pill mt-1">
                <vc:icon symbol="warning" />
            </div>
            <div>
                <h3 class="h5 mb-2">Back up this wallet</h3>
                <p class="text-secondary mb-0">This store has received funds. Save the seed phrase so you can recover the wallet later.</p>
            </div>
        </div>
        <div class="d-flex flex-wrap gap-2 flex-shrink-0">
            <form method="post" asp-controller="Ark" asp-action="ShowPrivateKey" asp-route-storeId="@storeId">
                <button type="submit" class="btn btn-warning" data-testid="backup-show-seed-btn">Show seed</button>
            </form>
            <form asp-action="UpdateWalletConfig" method="post" asp-route-storeId="@storeId">
                <input type="hidden" name="returnTo" value="overview" />
                <button type="submit" name="command" value="mark-wallet-backed-up" class="btn btn-link text-secondary text-decoration-none fw-semibold" data-testid="backup-mark-done-btn">
                    I saved the seed
                </button>
            </form>
        </div>
    </div>
}

<div class="bg-tile rounded p-3 p-sm-4 mb-3">
    <h3 class="h5 mb-3">Payments</h3>
    <div class="row row-cols-2 row-cols-md-3 row-cols-xl-5 g-3">
        @foreach (var stat in Model.PaymentStats)
        {
            var unit = Unit(stat.Unit);
            <div class="col">
                <div class="border-start ps-3 h-100">
                    <div class="text-truncate text-secondary small fw-semibold">@stat.Name</div>
                    <div class="d-flex flex-row align-items-baseline gap-1 mt-2">
                        <div class="fs-4 fw-semibold lh-1">@stat.Value.ToString("N0")</div>
                        @if (unit is not null)
                        {
                            <span class="text-secondary fw-semibold">@unit</span>
                        }
                    </div>
                </div>
            </div>
        }
        <div class="col">
            <div class="border-start ps-3 h-100">
                <div class="text-truncate text-secondary small fw-semibold">Receive fee</div>
                <div class="fs-4 fw-semibold lh-1 mt-2">@(Model.IsLightningEnabled ? FormatFeeRate(Model.BoltzReverseFeePercentage) : "Disabled")</div>
                @if (!string.IsNullOrEmpty(receiveNetworkFee))
                {
                    <div class="text-secondary small mt-2">@receiveNetworkFee</div>
                }
            </div>
        </div>
        <div class="col">
            <div class="border-start ps-3 h-100">
                <div class="text-truncate text-secondary small fw-semibold">Send fee</div>
                <div class="fs-4 fw-semibold lh-1 mt-2">@(Model.IsLightningEnabled ? FormatFeeRate(Model.BoltzSubmarineFeePercentage) : "Disabled")</div>
                @if (!string.IsNullOrEmpty(sendNetworkFee))
                {
                    <div class="text-secondary small mt-2">@sendNetworkFee</div>
                }
            </div>
        </div>
    </div>
</div>

<div class="bg-tile rounded p-3 p-sm-4 mb-3">
    @if (Model.RecentPayments.Count > 0)
    {
        <h3 class="h5 mb-3">Recent payments</h3>
        <div>
            @for (var index = 0; index < Model.RecentPayments.Count; index++)
            {
                var payment = Model.RecentPayments[index];
                var prefix = payment.IsOutgoing ? "-" : "+";
                var statusLabel = StatusLabel(payment);
                var statusClass = StatusClass(payment);
                <div class="d-flex flex-column flex-sm-row justify-content-between align-items-sm-start gap-2 py-3 @(index == 0 ? "pt-0" : "border-top")">
                    <div class="min-w-0">
                        <div class="d-flex flex-wrap align-items-center gap-2">
                            <div class="fw-semibold">@payment.Title</div>
                            <span class="badge rounded-pill @statusClass">@statusLabel</span>
                        </div>
                        <div class="text-muted small">
                            @if (!string.IsNullOrEmpty(payment.Description))
                            {
                                <span>@payment.Description - </span>
                            }
                            <span>@payment.Date.ToLocalTime().ToString("g")</span>
                        </div>
                    </div>
                    <div class="text-sm-end flex-shrink-0">
                        <div class="fw-semibold" data-sensitive>@($"{prefix}{DisplayFormatter.Currency(payment.Amount, payment.Currency)}")</div>
                        @if (IsFinalizingPayment(payment))
                        {
                            <div class="text-secondary small">Finalizing payment</div>
                        }
                    </div>
                </div>
            }
        </div>
    }
    else if (!Model.HasPaymentServiceIssue)
    {
        <div class="d-flex flex-column flex-lg-row align-items-lg-center justify-content-between gap-3">
            <div class="min-w-0">
                <h3 class="h5 mb-1">Ready for first payment</h3>
                <div class="text-secondary">Create an invoice or open the receive screen. Payments will appear here once they arrive.</div>
            </div>
            <div class="d-flex flex-wrap gap-2 flex-shrink-0">
                <a asp-controller="UIInvoice" asp-action="CreateInvoice" asp-route-storeId="@storeId" class="btn btn-primary btn-sm">
                    <vc:icon symbol="nav-invoice" />
                    Create invoice
                </a>
                <a asp-action="Receive" asp-route-storeId="@storeId" class="btn btn-secondary btn-sm">
                    <vc:icon symbol="actions-receive" />
                    Receive
                </a>
            </div>
        </div>
    }
    else
    {
        <h3 class="h5 mb-3">Recent payments</h3>
        <div class="text-muted">No recent payments yet.</div>
    }
</div>

<div class="mt-3 mb-4">
    <button class="d-inline-flex align-items-center btn btn-link text-primary fw-semibold p-0 mb-3" type="button" data-bs-toggle="collapse" data-bs-target="#WalletDetails" aria-expanded="false" aria-controls="WalletDetails">
        <vc:icon symbol="caret-down" />
        <span class="ms-1">Wallet details</span>
    </button>

    <div id="WalletDetails" class="collapse">
        <div class="row g-4">
            <div class="col-xl-5">
                <div class="bg-tile rounded p-3 p-sm-4 h-100">
                    <h3 class="h5 mb-3">Wallet details</h3>
                    <dl class="row mb-0">
                        <dt class="col-5 text-muted fw-normal">Wallet type</dt>
                        <dd class="col-7 text-end">@(Model.WalletType == WalletType.HD ? "HD (BIP-39)" : "Legacy (nsec)")</dd>

                        <dt class="col-5 text-muted fw-normal">Wallet ID</dt>
                        <dd class="col-7 text-end">
                            @if (!string.IsNullOrEmpty(Model.WalletId))
                            {
                                <vc:truncate-center text="@Model.WalletId" classes="truncate-center-id" />
                            }
                        </dd>

                        <dt class="col-5 text-muted fw-normal">Private keys</dt>
                        <dd class="col-7 text-end">
                            <span class="badge @(Model.SignerAvailable ? "text-bg-success" : "text-bg-warning")">
                                @(Model.SignerAvailable ? "Available" : "Watch-only")
                            </span>
                        </dd>

                        <dt class="col-5 text-muted fw-normal">Auto-send</dt>
                        <dd class="col-7 text-end">
                            <span class="badge @(Model.IsDestinationSweepEnabled ? "text-bg-info" : "text-bg-secondary")">
                                @(Model.IsDestinationSweepEnabled ? "Enabled" : "Disabled")
                            </span>
                        </dd>

                        <dt class="col-5 text-muted fw-normal">Small amounts</dt>
                        <dd class="col-7 text-end">
                            <span class="badge @(Model.AllowSubDustAmounts ? "text-bg-info" : "text-bg-secondary")">
                                @(Model.AllowSubDustAmounts ? "Enabled" : "Disabled")
                            </span>
                        </dd>

                        @if (Model.WalletType == WalletType.HD)
                        {
                            <dt class="col-5 text-muted fw-normal">On-chain fallback</dt>
                            <dd class="col-7 text-end">
                                <span class="badge @(Model.BoardingEnabled ? "text-bg-info" : "text-bg-secondary")">
                                    @(Model.BoardingEnabled ? "Enabled" : "Disabled")
                                </span>
                            </dd>
                            @if (Model.BoardingEnabled)
                            {
                                <dt class="col-5 text-muted fw-normal">On-chain minimum</dt>
                                <dd class="col-7 text-end">@FormatSats(Model.MinBoardingAmountSats)</dd>
                            }
                        }
                    </dl>
                    @if (Model.RecoveryStatus is { } rec)
                    {
                        <div class="small mt-3" data-testid="recovery-status">
                            @if (rec.State == RecoveryState.Running)
                            {
                                <span class="text-muted"><span class="spinner-border spinner-border-sm"></span> Recovery in progress...</span>
                            }
                            else if (rec.State == RecoveryState.Completed)
                            {
                                <span class="text-muted">Last recovery: @rec.ContractsRecovered contracts, @rec.FundsSynced VTXOs, @rec.SwapsAudited swaps.</span>
                            }
                            else
                            {
                                <span class="text-danger">Last recovery failed: @rec.Error</span>
                            }
                        </div>
                    }
                </div>
            </div>
            <div class="col-xl-7">
                <div class="bg-tile rounded p-3 p-sm-4 h-100">
                    <h3 class="h5 mb-3">Activity</h3>
                    <div class="list-group list-group-flush">
                        <a asp-action="Vtxos" asp-route-storeId="@storeId" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center px-0">
                            <span>Received outputs</span>
                            <span class="badge text-bg-secondary">@Model.TotalVtxoCount</span>
                        </a>
                        <a asp-action="Intents" asp-route-storeId="@storeId" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center px-0">
                            <span>Queued payments</span>
                            <span class="badge text-bg-secondary">@Model.TotalIntentCount</span>
                        </a>
                        <a asp-action="Swaps" asp-route-storeId="@storeId" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center px-0">
                            <span>Lightning activity</span>
                            <span class="badge text-bg-secondary">@Model.TotalSwapCount</span>
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="clearWalletModal" tabindex="-1" aria-labelledby="clearWalletModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="clearWalletModalLabel">
                    <vc:icon symbol="warning" />
                    Clear wallet settings
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form asp-action="ClearWallet" method="post" asp-route-storeId="@storeId">
                <div class="modal-body">
                    <div class="alert alert-warning">
                        <strong>Warning:</strong> This will remove the wallet settings from this store.
                    </div>
                    <p class="mb-3">Are you sure you want to clear the wallet settings?</p>
                    <ul>
                        <li>Bitcoin payments will be disabled for this store.</li>
                        <li>Lightning payments will be disabled if they are currently enabled.</li>
                        <li>Funds are not deleted from the network.</li>
                    </ul>
                    @if (Model.SignerAvailable && !string.IsNullOrEmpty(Model.Wallet))
                    {
                        <div class="alert alert-info">
                            Back up the wallet before clearing these settings.
                        </div>
                    }
                    <p class="text-muted mb-0">You can re-import the wallet later with the same seed, key, address, or wallet ID.</p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-danger">Clear wallet</button>
                </div>
            </form>
        </div>
    </div>
</div>
